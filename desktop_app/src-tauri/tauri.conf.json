{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop_app",
  "version": "0.1.0",
  "identifier": "com.bless.desktopapp",
  "build": {
    "frontendDist": "../../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "desktop_app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "signCommand": "powershell.exe -ExecutionPolicy Bypass -File ..\\scripts\\sign.ps1 \"%1\""
    },
    "externalBin": ["bin/main"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
